
import Math (abs, sign, max, bitWidth, shr, shl, toFloat, round, cos, sin, sqrt, log, exp, atan2)
import Ordering

------------------------------------------------
-- TODO: You can't extend a type that's been constructed via macro.
-- But you can extend the type if it's not constructed via macro.
-- This behavior should be consistent.
-- The "generics" from the macro are not truly singleton/canonical. Thy should be.
-- TODO: Macro system can't accept non-generic-type arguments?
-- There's no way currntly to combine Absorbing and NonAbsorbing into a macro.

type Absorbing(v: int)

pure Absorbing(int) -> Absorbing = (v) {
  this(v)
}

pure Absorbing(float) -> Absorbing = (v) {
  this(round(v))
}

pure +(Absorbing, Absorbing) -> Absorbing = (a, b) {
  Absorbing(a.v + b.v)
}

pure *(Absorbing, Absorbing) -> Absorbing = (a, b) {
  Absorbing(a.v * b.v)
}

pure -(Absorbing, Absorbing) -> Absorbing = (a, b) {
  Absorbing(a.v - b.v)
}

pure /(Absorbing, Absorbing) -> Absorbing = (a, b) {
  Absorbing(a.v / b.v)
}

pure Absorbing.neg() -> Absorbing = () {
  Absorbing(-this.v)
}

pure compareAbsorbing(Absorbing, Absorbing) -> int = (t1, t2) {
  (t1 - t2).v
}

deriveOrderingFromInt<Absorbing, compareAbsorbing>

pure Absorbing.neuralValue() -> int = () {
  this.v
}

pure Absorbing.newFromNeuralValue(int) -> Absorbing = (x) {
  Absorbing(x)
}

------------------------------------------------
type NonAbsorbing(v: int)

pure NonAbsorbing(int) -> NonAbsorbing = (v) {
  this(v)
}

pure NonAbsorbing(float) -> NonAbsorbing = (v) {
  this(round(v))
}

pure +(NonAbsorbing, NonAbsorbing) -> NonAbsorbing = (a, b) {
  NonAbsorbing(a.v + b.v)
}

pure *(NonAbsorbing, NonAbsorbing) -> NonAbsorbing = (a, b) {
  NonAbsorbing(a.v * b.v)
}

pure -(NonAbsorbing, NonAbsorbing) -> NonAbsorbing = (a, b) {
  NonAbsorbing(a.v - b.v)
}

pure /(NonAbsorbing, NonAbsorbing) -> NonAbsorbing = (a, b) {
  NonAbsorbing(a.v / b.v)
}

pure NonAbsorbing.neg() -> NonAbsorbing = () {
  NonAbsorbing(-this.v)
}

pure compareNonAbsorbing(NonAbsorbing, NonAbsorbing) -> int = (t1, t2) {
  (t1 - t2).v
}

deriveOrderingFromInt<NonAbsorbing, compareNonAbsorbing>

pure NonAbsorbing.neuralValue() -> int = () {
  match
  | this.v < 0 -> this.v-1
  | this.v > 0 -> this.v+1
  | _ -> -1
}

pure NonAbsorbing.newFromNeuralValue(int) -> NonAbsorbing = (x) {
  let v = match
  | x < 0 -> x+1
  | x > 0 -> x-1
  | _ -> 0
  NonAbsorbing(v)
}

------------------------------------------------------------------------

macro TractionMacro<T> = {
  type Traction(num: T, denom: T)
  
  -- Bit-budget normalization: after any construction, if either component
  -- exceeds 30 significant bits, right-shift both by the minimum amount
  -- needed so the largest fits in 30 bits. Signs on num and denom are
  -- preserved independently — Traction does NOT sign-migrate like Rational,
  -- since operations like `*_ndot` legitimately produce (24, -7) etc. where
  -- the sign of denom carries quadrant information.
  --
  -- The 30-bit budget keeps products of two Tractions at ≤ 60 bits, well
  -- under the 63-bit signed-long headroom, so the arithmetic chain never
  -- overflows. Long animation loops (quaternion composition per frame)
  -- trade exact-rational purity for bounded magnitude — the cube stays
  -- rotating smoothly indefinitely instead of overflowing after a few
  -- thousand frames.
  pure Traction(T, T) -> Traction = (num, denom) {
    let maxB = max(bitWidth(abs(num)), bitWidth(abs(denom)))
    let k = max(0, maxB - 30)
    match
    | k == 0 -> this(num, denom)
    | _ -> {
        let half = shl(1, k - 1)
        let nAbs = shr(abs(num) + half, k)
        let dAbs = shr(abs(denom) + half, k)
        this(sign(num) * nAbs, sign(denom) * dAbs)
      }
  }
  
  
  pure Traction(T) -> Traction = (n) {
    this(n, 1)
  }
  
  const Traction.zero = Traction(0,1)
  
  pure +(Traction, Traction) -> Traction = ((n1,d1), (n2,d2)) {
    Traction(n1*d2 + n2*d1, d1*d2)
  }
  
  pure *(Traction, Traction) -> Traction = ((n1,d1), (n2,d2)) {
    Traction(n1*n2, d1*d2)
  }
  
  pure *_dot(Traction, Traction) -> T = ((n1,d1), (n2,d2)) {
    d1*d2 + n1*n2
  }
  
  pure *_wedge(Traction, Traction) -> T = ((n1,d1), (n2,d2)) {
    d1*n2 - n1*d2
  }
  
  -- Dot product with second operand conjugated: t1 *_dot t2.conj()
  -- Equivalently: real part of complex product (d1+n1·i)(d2+n2·i)
  pure *_ndot(Traction, Traction) -> T = ((n1,d1), (n2,d2)) {
    d1*d2 - n1*n2
  }
  
  -- Wedge product with second operand conjugated: t1 *_wedge t2.conj()  
  -- Equivalently: imaginary part of complex product (d1+n1·i)(d2+n2·i)
  pure *_nwedge(Traction, Traction) -> T = ((n1,d1), (n2,d2)) {
    d1*n2 + n1*d2
  }
  
  pure Traction.neg() -> Traction = () {
    Traction(-this.num, -this.denom)
  }
  
  pure -(Traction, Traction) -> Traction = (t1, t2) {
    t1 + t2.neg()
  }
  
  pure Traction.inv() -> Traction = () {
    Traction(this.denom, this.num)
  }
  
  pure /(Traction, Traction) -> Traction = (t1, t2) {
    t1 * t2.inv()
  }
  
  pure compare(Traction, Traction) -> T = (t1, t2) {
    (t1 - t2).0
  }

  deriveOrderingFromInt<Traction, compare>
  
  pure Traction.conj() -> Traction = () {
    Traction(-this.num, this.denom)
  }
  
  promote int -> Traction = (i) {
    Traction(i)
  }
  
  pure Traction.toFloat() -> float = ((n, d)) {
    match d
    | 0 -> 0.0
    | _ -> toFloat(n) / toFloat(d)
  }
  emit Traction
}

type Traction = TractionMacro<int>

-------------------------------------------------

