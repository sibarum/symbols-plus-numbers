-- Canvas Grid — plotting with the plot module
import Canvas
import spn.canvas.plot

canvas(800, 600)
clear(0.08, 0.08, 0.1)

-- Draw a grid
drawGrid(800.0, 600.0, 50.0, 50.0, 0.5)

-- Draw axes centered in the window
drawAxes(400.0, 300.0, 800.0, 600.0, 2.0)

-- Draw some colored boxes
fill(0.3, 0.5, 0.9)
drawBox(100.0, 100.0, 120.0, 80.0)

fill(0.9, 0.4, 0.3)
drawBox(450.0, 350.0, 150.0, 100.0)

fill(0.3, 0.8, 0.5)
drawBox(250.0, 400.0, 100.0, 60.0)

show()
